# Cosign — environment contract (copy to infra/.env and fill in).
# Single source of truth for env vars across all services (WORKSTREAMS WS4 §6).

# === Database ===
POSTGRES_USER=cosign
POSTGRES_PASSWORD=changeme
POSTGRES_DB=cosign
DATABASE_URL=postgres://cosign:changeme@postgres:5432/cosign?sslmode=disable

# === Redis ===
REDIS_URL=redis://redis:6379

# === GitHub App (cosign-api owns these — see WS1 Phase 2) ===
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=/run/secrets/github_app_key
GITHUB_WEBHOOK_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
# OAuth callback the GitHub App is configured with (must match exactly)
GITHUB_OAUTH_REDIRECT_URL=http://localhost:8080/auth/github/callback

# === JWT (cosign-api) — RS256 keypair (PEM). Generate with scripts/gen-keys.sh ===
JWT_RSA_PRIVATE_KEY_PATH=/run/secrets/jwt_private.pem
JWT_RSA_PUBLIC_KEY_PATH=/run/secrets/jwt_public.pem

# === User OAuth token encryption (cosign-api) ===
# 32 bytes base64 for AES-GCM — populated by scripts/gen-keys.sh
OAUTH_TOKEN_ENCRYPTION_KEY=

# === LLM providers (cosign-worker — per-role keys, see config/llm-routing.yaml) ===
ANTHROPIC_API_KEY=
ANTHROPIC_CHEAP_API_KEY=      # optional: separate billing for Haiku
GROQ_API_KEY=
OPENAI_API_KEY=

# === Search tools ===
BRAVE_API_KEY=
SERPER_API_KEY=               # alternative

# === Service URLs / gRPC wiring ===
API_BASE_URL=http://cosign-api:8080
API_GRPC_ADDR=cosign-api:50051        # worker -> api (identity service)
API_GRPC_LISTEN_ADDR=:50051
WORKER_GRPC_ADDR=cosign-worker:50052  # api -> worker (orchestration)
WORKER_GRPC_LISTEN_ADDR=0.0.0.0:50052
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# === Sandbox driver ===
SANDBOX_DRIVER=docker         # docker | k8s (k8s is post-hackathon)
SANDBOX_IMAGE=cosign/sandbox:latest
SANDBOX_NETWORK=cosign_sandbox_net

# === LLM routing ===
# Real providers: config/llm-routing.yaml (defaults all roles to Anthropic Haiku).
# Keyless dev/demo: config/llm-routing.mock.yaml (synthetic responses).
LLM_ROUTING_CONFIG=config/llm-routing.yaml

# === Demo budget cap (shared operator key) ===
# Per-user lifetime spend cap (USD) on the SHARED key. 0 = disabled (no cap).
# Users who add their own key in /settings are uncapped (their own billing).
DEMO_USER_CAP_USD=0.50
DEMO_DEFAULT_PROVIDER=anthropic
DEMO_DEFAULT_MODEL=anthropic/claude-haiku-4-5-20251001

# === Web (browser-reachable api URL, inlined at build time) ===
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
WEB_BASE_URL=http://localhost:3000

# === Observability ===
LOG_LEVEL=info
LOG_FORMAT=json
